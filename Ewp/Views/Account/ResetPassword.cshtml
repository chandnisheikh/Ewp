@{
}
@{
    Layout = null;
}

<h3>Reset Password</h3>

<form method="post">

    <input type="hidden" name="token" value="@Context.Request.Query["token"]" />

    <input name="password" type="password" class="form-control" placeholder="New Password" />

    <button class="btn btn-success mt-2">

        Reset Password

    </button>

</form>