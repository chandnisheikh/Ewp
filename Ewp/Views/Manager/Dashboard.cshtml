@{
    ViewData["Title"] = "Manager Dashboard";
}

<h2>Manager Dashboard</h2>

<div class="row mt-4">

    <!-- TOTAL EMPLOYEES -->
    <div class="col-md-3">
        <div class="card bg-primary text-white p-3">
            <h5>Total Employees</h5>
            <h2>@ViewBag.TotalEmployees</h2>
        </div>
    </div>

    <!-- TOTAL TASKS -->
    <div class="col-md-3">
        <div class="card bg-success text-white p-3">
            <h5>Total Tasks</h5>
            <h2>@ViewBag.TotalTasks</h2>
        </div>
    </div>

    <!-- COMPLETED TASKS -->
    <div class="col-md-3">
        <div class="card bg-info text-white p-3">
            <h5>Completed Tasks</h5>
            <h2>@ViewBag.CompletedTasks</h2>
        </div>
    </div>

    <!-- PENDING TASKS -->
    <div class="col-md-3">
        <div class="card bg-warning text-dark p-3">
            <h5>Pending Tasks</h5>
            <h2>@ViewBag.PendingTasks</h2>
        </div>
    </div>

</div>

<hr />

<!-- ✅ CHART SECTION -->
<h4>Task Status Graph</h4>

<canvas id="taskChart" height="120"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // SAFE VALUES FROM VIEWBAG
    var completed = @((ViewBag.CompletedTasks != null) ? ViewBag.CompletedTasks : 0);
    var pending = @((ViewBag.PendingTasks != null) ? ViewBag.PendingTasks : 0);

    // DEBUG (optional)
    console.log("Completed:", completed);
    console.log("Pending:", pending);

    var ctx = document.getElementById('taskChart').getContext('2d');

    new Chart(ctx, {
    type: 'pie',
    data: {
    labels: ['Completed', 'Pending'],
    datasets: [{
    data: [completed, pending],
    backgroundColor: ['#28a745', '#ffc107']
    }]
    },
    options: {
    responsive: true,
    plugins: {
    legend: {
    position: 'bottom'
    }
    }
    }
    });
</script>

<hr />

<!-- QUICK ACTIONS -->
<h4>Quick Actions</h4>

<div class="mt-3">

    <a asp-controller="Manager" asp-action="AssignTask" class="btn btn-primary m-1">
        Assign Task
    </a>

    <a asp-controller="Manager" asp-action="TaskStatus" class="btn btn-info m-1">
        View Tasks
    </a>

    <a asp-controller="Manager" asp-action="Employees" class="btn btn-success m-1">
        Employees
    </a>

    <a asp-controller="Manager" asp-action="Queries" class="btn btn-dark m-1">
        Manage Employee Queries
    </a>

    <a asp-controller="Manager" asp-action="Expenses" class="btn btn-warning m-1">
        Expenses
    </a>

</div>