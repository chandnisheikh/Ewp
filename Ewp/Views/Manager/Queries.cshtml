@model List<Ewp.Models.Query>

<h2>Employee Queries</h2>

<table class="table table-bordered table-hover shadow">
    <thead class="table-dark">
        <tr>
            <th>Employee</th>
            <th>Subject</th>
            <th>Message</th>
            <th>Status</th>
            <th>Reply</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var q in Model)
        {
            <tr>
                <td>@(q.Employee?.Name ?? "N/A")</td>
                <td>@q.Subject</td>
                <td>@q.Message</td>
                <td>@q.Status</td>

                <!-- ✅ FIXED LINE -->
                <td>@(q.Reply ?? "Not replied yet")</td>

                <td>
                    <a asp-action="ReplyQuery" asp-route-id="@q.Id" class="btn btn-sm btn-primary">
                        Reply
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>