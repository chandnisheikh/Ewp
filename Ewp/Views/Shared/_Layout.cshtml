<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ewp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ewp.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <!-- 🔵 TOP NAVBAR -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand">Employee Management System</span>

            <a href="/Account/Logout" class="btn btn-danger">Logout</a>
        </div>
    </nav>

    <div class="d-flex">

        <!-- 🟡 SIDEBAR -->
        <div style="width:220px; background:#f8f9fa; min-height:100vh; padding:15px;">
            <h5>Menu</h5>
            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link" href="/Home/Index">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Admin/Index">Admin</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Manager/Index">Manager</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Employee/Index">Employee</a>
                </li>

            </ul>
        </div>

        <!-- 🟢 MAIN CONTENT -->
        <div class="container" style="margin-top:20px;">
            @RenderBody()
        </div>

    </div>

    <!-- 🔻 FOOTER -->
    <footer class="border-top footer text-muted text-center mt-3">
        <div class="container">
            &copy; 2026 - Ewp
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
