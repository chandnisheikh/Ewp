<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>HRM System</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
            body {
                background: #f8f9fc;
                font-family: Segoe UI;
            }

            .sidebar {
                height: 100vh;
                background: #1e293b;
                color: white;
                padding: 20px;
            }

                .sidebar a {
                    display: block;
                    color: #cbd5e1;
                    padding: 12px;
                    border-radius: 8px;
                    text-decoration: none;
                    margin-bottom: 8px;
                }

                    .sidebar a:hover {
                        background: #334155;
                        color: white;
                    }

            .topbar {
                background: white;
                padding: 15px;
                box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            }
    </style>
</head>

<body>

    @using Microsoft.AspNetCore.Http
@{
        var role = Context.Session.GetString("Role");
        var username = Context.Session.GetString("Username");
    }

    <div class="container-fluid">
        <div class="row">

            <!-- SIDEBAR -->
            <div class="col-2 sidebar">

                <h4>HRM</h4>

                @if (role == "Admin")
                {
                    <a href="/Admin/Dashboard">Dashboard</a>
                    <a href="/Admin/Users">Users</a>
                    <a href="/Admin/Employees">Employees</a>
                    <a href="/Admin/SalaryList">Salary</a>
                    <a href="/Admin/SystemReport">Reports</a>
                }
                else if (role == "Manager")
                {
                    <a href="/Manager/Dashboard">Dashboard</a>
                    <a href="/Manager/Employees">Employees</a>
                    <a href="/Manager/AssignTask">Assign Task</a>
                    <a href="/Manager/TaskStatus">Task Status</a>
                }
                else if (role == "Employee")
                {
                    <a href="/Employee/Dashboard">Dashboard</a>
                }

                <hr />

                <!-- ✅ LOGOUT FIX -->
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button class="btn btn-danger w-100">
                        Logout
                    </button>
                </form>

            </div>

            <!-- MAIN -->
            <div class="col-10">

                <div class="topbar d-flex justify-content-between">
                    <h5>HRM System</h5>
                    <span>👤 @username</span>
                </div>

                <div class="p-4">
                    @RenderBody()
                </div>

            </div>

        </div>
    </div>

    <!-- 🔥 THIS FIXES YOUR ERROR -->
    @RenderSection("Scripts", required: false)

</body>
</html>