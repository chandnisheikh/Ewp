@model Ewp.Models.Employee

<h2>Add Employee</h2>

<form method="post">

    <h4>Basic Details</h4>

    <input asp-for="Name" placeholder="Full Name" class="form-control" /><br />
    <input asp-for="Email" placeholder="Email" class="form-control" /><br />
    <input asp-for="Phone" placeholder="Phone" class="form-control" /><br />

    <h4>Job Details</h4>

    <input asp-for="Designation" placeholder="Designation" class="form-control" /><br />

    <select asp-for="DepartmentId" class="form-control">
        <option value="">Select Department</option>
        @foreach (var d in ViewBag.Departments)
        {
            <option value="@d.Id">@d.Name</option>
        }
    </select><br />

    <input asp-for="Salary" placeholder="Base Salary" class="form-control" /><br />

    <h4>Login Credentials</h4>

    <input type="text" name="Username" placeholder="Username" class="form-control" /><br />
    <input type="password" name="Password" placeholder="Password" class="form-control" /><br />

    <button type="submit" class="btn btn-success">Create Employee</button>

</form>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}