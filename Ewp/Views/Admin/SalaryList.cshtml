@model List<Ewp.Models.Salary>

<h2 class="mb-4">💰 Salary Management</h2>

<a asp-action="GenerateSalaryAll" class="btn btn-warning mb-3">
    Generate Monthly Salary
</a>

<table class="table table-striped table-hover shadow">

    <thead class="table-dark">
        <tr>
            <th>Employee</th>
            <th>Department</th>
            <th>Base</th>
            <th>Bonus</th>
            <th>Deduction</th>
            <th>Total</th>
            <th>Date</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Employee?.Name</td>
                <td>@s.Employee?.Department?.Name</td>
                <td>@s.BaseSalary</td>
                <td class="text-success">+@s.Bonus</td>
                <td class="text-danger">-@s.Deduction</td>
                <td><b>@s.TotalSalary</b></td>
                <td>@s.Date.ToString("dd-MM-yyyy")</td>
            </tr>
        }
    </tbody>

</table>