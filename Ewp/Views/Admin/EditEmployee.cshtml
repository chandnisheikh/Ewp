@model Ewp.Models.Employee

<h2 class="mb-4">Edit Employee</h2>

<form method="post" class="card p-4 shadow">

    <input type="hidden" asp-for="Id" />

    <!-- ================= BASIC DETAILS ================= -->
    <h4 class="mb-3 text-primary">Basic Details</h4>

    <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input asp-for="Name" class="form-control" placeholder="Enter full name" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input asp-for="Email" class="form-control" placeholder="Enter email" />
    </div>

    <div class="mb-3">
        <label class="form-label">Phone</label>
        <input asp-for="Phone" class="form-control" placeholder="Enter phone number" />
    </div>

    <!-- ================= JOB DETAILS ================= -->
    <h4 class="mt-4 mb-3 text-success">Job Details</h4>

    <div class="mb-3">
        <label class="form-label">Designation</label>
        <input asp-for="Designation" class="form-control" placeholder="Enter designation" />
    </div>

    <div class="mb-3">
        <label class="form-label">Department</label>
        <select asp-for="DepartmentId" class="form-control">
            <option value="">Select Department</option>
            @foreach (var d in ViewBag.Departments)
            {
                <option value="@d.Id">@d.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Salary</label>
        <input asp-for="Salary" class="form-control" placeholder="Enter salary" />
    </div>

    <!-- ================= ACTION BUTTONS ================= -->
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Update Employee</button>
        <a href="/Admin/Employees" class="btn btn-secondary">Cancel</a>
    </div>

</form>