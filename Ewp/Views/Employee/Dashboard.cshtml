@model dynamic

<h2 class="mb-4">👨‍💼 Employee Dashboard</h2>

<div class="row">

    <!-- PROFILE CARD -->
    <div class="col-md-4">
        <div class="card shadow p-3">
            <h4>My Profile</h4>
            <hr />

            <p><b>Name:</b> @ViewBag.Employee?.Name</p>
            <p><b>Email:</b> @ViewBag.Employee?.Email</p>
            <p><b>Department:</b> @ViewBag.Employee?.Department?.Name</p>
            <p><b>Designation:</b> @ViewBag.Employee?.Designation</p>
        </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="col-md-8">
        <div class="card shadow p-3">
            <h4>Quick Actions</h4>
            <hr />

            <a asp-controller="Employee" asp-action="CreateQuery" class="btn btn-warning m-1">
                Raise Query
            </a>

            <a asp-controller="Employee" asp-action="MyQueries" class="btn btn-info m-1">
                My Queries
            </a>
        </div>
    </div>

</div>

<hr />

<!-- TASK SECTION -->
<h4>My Tasks</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @if (ViewBag.Tasks != null)
        {
            foreach (var t in ViewBag.Tasks)
            {
                <tr>
                    <td>@t.Title</td>
                    <td>@t.Status</td>
                    <td>
                        <a asp-controller="Employee"
                               asp-action="UpdateStatus"
                               asp-route-id="@t.Id"
                               class="btn btn-success btn-sm">
                            Complete
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<hr />

<!-- EXPENSE SECTION -->
<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Amount</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>
        @if (ViewBag.Expenses != null)
        {
            foreach (var e in ViewBag.Expenses)
            {
                <tr>
                    <td>₹ @e.Amount</td>
                    <td>
                        <span class="badge bg-info">@e.Status</span>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<hr />

<!-- ACTIVITY CHART -->
<h4>My Activity</h4>

<!-- embed counts into DOM to avoid Razor inside <script> -->
<div id="empData"
     data-tasks="@((ViewBag.Tasks != null) ? ViewBag.Tasks.Count : 0)"
     data-expenses="@((ViewBag.Expenses != null) ? ViewBag.Expenses.Count : 0)"
     style="display:none"></div>

<canvas id="empChart" height="120"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // read numeric values from data-* attributes (no Razor inside this script)
    const dataEl = document.getElementById('empData');
    const tasks = parseInt(dataEl.dataset.tasks, 10) || 0;
    const expenses = parseInt(dataEl.dataset.expenses, 10) || 0;

    const ctx = document.getElementById('empChart').getContext('2d');

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Tasks', 'Expenses'],
            datasets: [{
                label: 'My Activity',
                data: [tasks, expenses]
            }]
        }
    });
</script>

<!-- ACTION BUTTONS -->
<div class="mt-3">

    <a asp-controller="Employee" asp-action="CreateExpense" class="btn btn-warning">
        Submit Expense
    </a>

    <a asp-controller="Employee" asp-action="MyExpenses" class="btn btn-info">
        My Expenses
    </a>

</div>